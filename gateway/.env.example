# Vercel project env vars (never commit real values)

# Client key checked against x-api-key header from the iOS app
SAVY_API_KEY=generate-a-long-random-string

# Vercel cron auth for /api/v1/rdf/sync-entries (hourly belief → RDF sync)
# CRON_SECRET=generate-a-long-random-string

# Phase 1 bridge — reads live data from Supabase until Aurora is live
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cognito auth (gateway signs users in on behalf of iOS app)
# COGNITO_USER_POOL_ID=us-west-2_sqayHoHrK
# COGNITO_CLIENT_ID=omkdcfdi0rsems3fmc7r5r797
# COGNITO_REGION=us-west-2
# Public mobile app client (no COGNITO_CLIENT_SECRET required)

# Phase 2 — Neo4j enrichment for ontology (optional)
# NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_DATABASE=neo4j
# NEO4J_PASSWORD=

# Phase 2 — Aurora IAM auth (preferred on Vercel)
# AURORA_HOST=savy-aurora.cluster-xxxx.us-west-2.rds.amazonaws.com
# AURORA_DB=postgres
# AURORA_USER=postgres
# AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
