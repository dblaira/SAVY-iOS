{
  "name": "savy-gateway",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "test": "npm run test:engine && npm run test:gateway",
    "test:engine": "npm --prefix ../packages/suite-graph-engine test",
    "test:gateway": "node --import tsx --test test/**/*.test.ts",
    "import:suite-rdf": "node --import tsx scripts/import-suite-triples.ts",
    "import:belief-entries-rdf": "node --import tsx scripts/import-belief-entries-rdf.ts",
    "import:axiom-rdf": "node --import tsx scripts/import-axiom-rdf.ts",
    "sync:graph-rdf": "node --import tsx scripts/sync-graph-rdf.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1072.0",
    "@aws-sdk/rds-signer": "^3.1072.0",
    "@supabase/supabase-js": "^2.49.1",
    "@vercel/node": "^5.0.4",
    "neo4j-driver": "^5.28.3",
    "pg": "^8.14.1",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vercel": "^41.1.4"
  },
  "engines": {
    "node": "20.x"
  }
}
